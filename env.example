# ─────────────────────────────────────────────────────────────
# RoastCV — Environment Variables Template
# Copy this file to ".env" and fill in your actual values.
# Never commit your real ".env" file to GitHub.
# ─────────────────────────────────────────────────────────────

# ── LLM Provider Selection ──────────────────────────────────────
# Choose one: gemini | groq | cerebras | mistral | github | azure
LLM_PROVIDER=gemini

# Optional: comma-separated fallback providers (used automatically
# if the primary provider fails or hits a rate limit)
# Example: FALLBACK_PROVIDERS=groq,cerebras,mistral
FALLBACK_PROVIDERS=

# ── Google Gemini ────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Groq ────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_ENDPOINT=https://api.groq.com/openai/v1

# ── Cerebras ─────────────────────────────────────────────────────
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b
CEREBRAS_ENDPOINT=https://api.cerebras.ai/v1

# ── Mistral AI ───────────────────────────────────────────────────
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_ENDPOINT=https://api.mistral.ai/v1

# ── GitHub Models ────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_MODEL=gpt-4.1-mini
GITHUB_ENDPOINT=https://models.inference.ai.azure.com

# ── Azure OpenAI ─────────────────────────────────────────────────
AZURE_ENDPOINT=
AZURE_API_KEY=
AZURE_DEPLOYMENT=gpt-4.1-mini
AZURE_API_VERSION=2024-10-21

# ── General Settings ─────────────────────────────────────────────
MAX_TOKENS=8192
OUTPUT_DIR=output
